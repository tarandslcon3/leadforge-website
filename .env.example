# Jotform API Key — used server-side (API routes) to forward chatbot leads
# Get it: jotform.com → Account → API → Create API Key → copy the key
# Add to Vercel: vercel.com → Project → Settings → Environment Variables
JOTFORM_API_KEY=your-key-here

# Jotform API Key — used client-side (contact form submits directly to Jotform)
# Same key as above — add BOTH to Vercel Environment Variables
NEXT_PUBLIC_JOTFORM_API_KEY=your-key-here

# Google Analytics 4 Measurement ID (optional)
# Get it: analytics.google.com → Admin → Data Streams → your stream → Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Site URL
NEXT_PUBLIC_SITE_URL=https://leadforge-website-inky.vercel.app
